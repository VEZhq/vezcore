# Primary VEZcore PostgreSQL on Proxmox and private PostgREST gateway
DATABASE_URL=
DATABASE_POOL_MAX=10
DATABASE_SSL=disable
VEZCORE_DATABASE_API_URL=http://vezcore-postgrest:3000
VEZCORE_DATABASE_API_KEY=replace-with-a-long-random-secret

# Authentication
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
BETTER_AUTH_ALLOW_SIGNUP=false
HEALTH_CHECK_TOKEN=

# VEZcore object storage
S3_ENDPOINT=https://s3-dev.vezlabs.dev
S3_PUBLIC_URL=https://s3-dev.vezlabs.dev
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vezcore-dev

# VEZvision CMS administration API. Development can use the private lab
# endpoint; production must use the authenticated public HTTPS gateway.
VEZVISION_DATABASE_API_URL=https://api.vezvision.com/admin/v1
VEZVISION_DATABASE_API_KEY=replace-with-a-different-long-random-secret
VEZVISION_PUBLIC_URL=https://vezvision.vezlabs.dev
VEZVISION_FUNCTIONS_API_URL=https://api.vezlabs.dev/functions/v1
VEZVISION_S3_ENDPOINT=https://s3-dev.vezlabs.dev
VEZVISION_S3_PUBLIC_URL=https://s3-dev.vezlabs.dev
VEZVISION_S3_REGION=us-east-1
VEZVISION_S3_ACCESS_KEY=
VEZVISION_S3_SECRET_KEY=
VEZVISION_S3_BUCKET=vezvision-dev

RESEND_API_KEY=
NEWSLETTER_DISPATCH_TOKEN=

# Deployment
# Set FORCE_HTTPS=true when serving over HTTPS (e.g. Coolify with TLS).
# Leave empty for plain HTTP homelab deployments — controls CSP
# upgrade-insecure-requests, HSTS, and secure cookie flags.
FORCE_HTTPS=
# Public URL of the app (used for CORS allowlist in /api routes).
NEXT_PUBLIC_APP_URL=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_SECURITY_CHANNEL_ID=
DISCORD_AUDIT_CHANNEL_ID=
DISCORD_USERS_CHANNEL_ID=
DISCORD_SYSTEM_CHANNEL_ID=
DISCORD_INTEGRATIONS_CHANNEL_ID=

# Dev origins
DEV_ORIGIN_IP=

# One-time bootstrap (remove from Coolify after the first admin is created)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# VezVision files retention
VEZVISION_FILES_RETENTION_SECRET=
VEZVISION_FILES_RETENTION_DAYS=
